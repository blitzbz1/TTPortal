          "expr": "sum by (function) (rate({job=\"supabase_edge_functions\", type=\"request\"} [1m]))",
          "legendFormat": "{{function}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 latency by route",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
          "expr": "quantile_over_time(0.95, {job=\"supabase_edge_functions\", type=\"request\"} | json | unwrap data_duration_ms [5m]) by (function)",
          "legendFormat": "{{function}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error rate by route (4xx + 5xx)",
      "type": "timeseries",
