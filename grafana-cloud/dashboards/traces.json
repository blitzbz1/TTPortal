      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
          "expr": "sum by (function) (rate({job=\"supabase_edge_functions\", type=\"request\"} | json | data_status >= 400 [5m]))",
          "legendFormat": "{{function}}"
