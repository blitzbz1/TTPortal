      "id": 1,
      "title": "Request rate by route",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "refId": "A",
